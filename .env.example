# Public Supabase values (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional: keeps the UI usable before Supabase is connected.
NEXT_PUBLIC_DEMO_MODE=true

# User management uses the Edge Function `admin-users` (service role stays on Supabase).
# No SERVICE_ROLE_KEY is required in the Next.js host for create/edit/delete users.
